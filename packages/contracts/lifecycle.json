{
  "version": "1.0.0",
  "sddTransitions": {
    "intent": ["spec-draft"],
    "spec-draft": ["spec-reviewed"],
    "spec-reviewed": ["spec-approved", "spec-draft"],
    "spec-approved": ["planned"],
    "planned": ["implementation-ready"],
    "implementation-ready": ["implementing"],
    "implementing": ["verifying"],
    "verifying": ["release-ready", "implementing"],
    "release-ready": ["released"],
    "released": []
  },
  "deliveryTransitions": {
    "candidate": ["judge-ready"],
    "judge-ready": ["subtask-ready"],
    "subtask-ready": ["pup-complete"],
    "pup-complete": ["lead-integrated"],
    "lead-integrated": ["tests-passed"],
    "tests-passed": ["judge-approved"],
    "judge-approved": ["merge-ready"],
    "merge-ready": []
  },
  "batchTransitions": {
    "batch-open": ["three-or-four-stories-merged"],
    "three-or-four-stories-merged": ["shepherd-review"],
    "shepherd-review": ["continue", "corrective-work", "human-escalation"],
    "continue": ["batch-open"],
    "corrective-work": ["shepherd-review", "batch-open"],
    "human-escalation": []
  },
  "shepherdCheckpointEvery": { "min": 3, "max": 3 },
  "shepherdCheckpointBlocking": false
}
