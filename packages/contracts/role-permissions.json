{
  "version": "1.0.0",
  "roles": {
    "orchestrator": {
      "canMutateCode": false,
      "canMutateTickets": false,
      "canApproveMerge": false,
      "canEscalateToHuman": true,
      "readonly": true,
      "allowedActions": [
        "plan",
        "schedule",
        "launch-role",
        "evaluate-gates",
        "recover",
        "escalate"
      ],
      "forbiddenActions": ["edit-source", "merge-pr", "mutate-jira"]
    },
    "nose": {
      "canMutateCode": false,
      "canMutateTickets": false,
      "canApproveMerge": false,
      "canEscalateToHuman": false,
      "readonly": true,
      "allowedActions": [
        "search",
        "read",
        "inventory",
        "cite",
        "report-gaps"
      ],
      "forbiddenActions": [
        "edit-source",
        "run-mutating-shell",
        "approve",
        "merge"
      ]
    },
    "pup": {
      "canMutateCode": true,
      "canMutateTickets": false,
      "canApproveMerge": false,
      "canEscalateToHuman": false,
      "readonly": false,
      "allowedActions": [
        "implement-subtask",
        "write-tests",
        "request-discovery",
        "commit-in-worktree"
      ],
      "forbiddenActions": ["merge-pr", "approve-design", "mutate-jira"]
    },
    "lead": {
      "canMutateCode": true,
      "canMutateTickets": false,
      "canApproveMerge": false,
      "canEscalateToHuman": false,
      "readonly": false,
      "allowedActions": [
        "integrate-subtasks",
        "resolve-conflicts",
        "run-story-tests",
        "request-discovery",
        "prepare-pr"
      ],
      "forbiddenActions": ["final-judge-approve", "shepherd-verdict"]
    },
    "judge": {
      "canMutateCode": false,
      "canMutateTickets": false,
      "canApproveMerge": false,
      "canEscalateToHuman": true,
      "readonly": true,
      "allowedActions": [
        "preflight-review",
        "parity-review",
        "approve-story",
        "reject-story",
        "request-discovery",
        "escalate"
      ],
      "forbiddenActions": [
        "edit-source",
        "merge-pr",
        "shepherd-verdict",
        "mutate-jira"
      ]
    },
    "shepherd": {
      "canMutateCode": false,
      "canMutateTickets": false,
      "canApproveMerge": false,
      "canEscalateToHuman": true,
      "readonly": true,
      "allowedActions": [
        "checkpoint-review",
        "verdict-continue",
        "verdict-correct",
        "verdict-escalate",
        "request-discovery"
      ],
      "forbiddenActions": ["edit-source", "merge-pr"]
    }
  }
}
