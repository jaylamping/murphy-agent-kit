{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://murphy-agent-kit.local/schemas/handoff.schema.json",
  "title": "Murphy Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "handoffId",
    "fromRole",
    "toRole",
    "kind",
    "payload",
    "createdAt"
  ],
  "properties": {
    "version": { "type": "string", "const": "1.0.0" },
    "handoffId": { "type": "string", "minLength": 1 },
    "fromRole": {
      "type": "string",
      "enum": [
        "orchestrator",
        "nose",
        "pup",
        "lead",
        "judge",
        "shepherd",
        "human"
      ]
    },
    "toRole": {
      "type": "string",
      "enum": [
        "orchestrator",
        "nose",
        "pup",
        "lead",
        "judge",
        "shepherd",
        "human"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "discovery-request",
        "discovery-report",
        "story-brief",
        "subtask-brief",
        "implementation-result",
        "integration-result",
        "review-result",
        "shepherd-verdict",
        "escalation",
        "gate-failure"
      ]
    },
    "storyId": { "type": "string" },
    "subtaskId": { "type": "string" },
    "payload": { "type": "object" },
    "createdAt": { "type": "string", "format": "date-time" },
    "correlationId": { "type": "string" }
  }
}
