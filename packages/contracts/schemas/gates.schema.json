{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://murphy-agent-kit.local/schemas/gates.schema.json",
  "title": "Murphy Gates",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "gates"],
  "properties": {
    "version": { "type": "string", "const": "1.0.0" },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "when", "requiredEvidence", "blocking"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "when": {
            "type": "string",
            "enum": [
              "before-pup-start",
              "before-lead-integrate",
              "before-judge-approve",
              "before-merge",
              "before-shepherd-checkpoint",
              "before-sdd-transition"
            ]
          },
          "requiredEvidence": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "blocking": { "type": "boolean" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
