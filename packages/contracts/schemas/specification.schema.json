{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://murphy-agent-kit.local/schemas/specification.schema.json",
  "title": "Murphy Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "title",
    "objectives",
    "scope",
    "nonGoals",
    "requirements",
    "constraints",
    "acceptanceCriteria",
    "traceability"
  ],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "objectives": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in", "out"],
      "properties": {
        "in": { "type": "array", "items": { "type": "string" } },
        "out": { "type": "array", "items": { "type": "string" } }
      }
    },
    "nonGoals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["must", "should", "could"]
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "summary"],
        "properties": {
          "id": { "type": "string" },
          "summary": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["proposed", "accepted", "superseded"]
          }
        }
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "requirementIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "traceability": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirementId", "workItemIds"],
        "properties": {
          "requirementId": { "type": "string" },
          "workItemIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "testIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidenceIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
