{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://murphy-agent-kit.local/schemas/escalation.schema.json",
  "title": "Murphy Escalation Rules",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "rules"],
  "properties": {
    "version": { "type": "string", "const": "1.0.0" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "trigger", "action", "severity"],
        "properties": {
          "id": { "type": "string" },
          "trigger": {
            "type": "string",
            "enum": [
              "gate-failure",
              "claim-conflict",
              "lease-stale",
              "model-unavailable",
              "principal-escalate",
              "credential-missing",
              "recovery-ambiguous",
              "human-required"
            ]
          },
          "action": {
            "type": "string",
            "enum": [
              "retry-with-fallback",
              "pause-lane",
              "reroute-to-architect",
              "open-corrective-work",
              "escalate-to-human",
              "abort-run"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["orchestrator", "architect", "principal", "human"]
          },
          "description": { "type": "string" }
        }
      }
    }
  }
}
