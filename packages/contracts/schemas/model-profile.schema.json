{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://murphy-agent-kit.local/schemas/model-profile.schema.json",
  "title": "Murphy Model Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "roles"],
  "properties": {
    "version": { "type": "string", "const": "1.0.0" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "roles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "orchestrator",
        "nose",
        "pup",
        "lead",
        "judge",
        "shepherd"
      ],
      "properties": {
        "orchestrator": { "$ref": "#/$defs/roleModel" },
        "nose": { "$ref": "#/$defs/roleModel" },
        "pup": { "$ref": "#/$defs/roleModel" },
        "lead": { "$ref": "#/$defs/roleModel" },
        "judge": { "$ref": "#/$defs/roleModel" },
        "shepherd": { "$ref": "#/$defs/roleModel" }
      }
    }
  },
  "$defs": {
    "roleModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary"],
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "fallback": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
