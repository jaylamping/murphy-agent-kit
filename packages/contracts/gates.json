{
  "version": "1.0.0",
  "gates": [
    {
      "id": "claims-declared",
      "name": "Resource claims declared",
      "when": "before-pup-start",
      "requiredEvidence": ["resource-claims", "story-brief"],
      "blocking": true,
      "description": "Pups cannot start until exclusive/shared claims are recorded."
    },
    {
      "id": "discovery-citations",
      "name": "Discovery citations present",
      "when": "before-pup-start",
      "requiredEvidence": ["discovery-report"],
      "blocking": true,
      "description": "Implementation requires Nose discovery with path/line citations."
    },
    {
      "id": "subtask-tests",
      "name": "Subtask tests passed",
      "when": "before-lead-integrate",
      "requiredEvidence": ["pup-test-log", "implementation-result"],
      "blocking": true
    },
    {
      "id": "story-integration",
      "name": "Story integration complete",
      "when": "before-judge-approve",
      "requiredEvidence": ["integration-result", "story-test-log"],
      "blocking": true
    },
    {
      "id": "judge-approval",
      "name": "Judge approval",
      "when": "before-merge",
      "requiredEvidence": ["review-result", "judge-approved"],
      "blocking": true
    },
    {
      "id": "shepherd-checkpoint",
      "name": "Shepherd checkpoint (advisory after ≥3 merges; does not pause unless blocking enabled)",
      "when": "before-shepherd-checkpoint",
      "requiredEvidence": ["merged-story-batch", "parity-or-regression-notes"],
      "blocking": false
    },
    {
      "id": "sdd-transition",
      "name": "SDD transition evidence",
      "when": "before-sdd-transition",
      "requiredEvidence": ["sdd-artifact", "gate-checksum"],
      "blocking": true
    }
  ]
}
